_G.AutoBlockEnabled = false

local LastBlockTime = 0
local BLOCK_COOLDOWN = 0.08

local function CreateHitboxVisual()
    local part = Instance.new("Part")
    part.Name = "AttackHitboxVisual"
    part.Size = GetHitboxSize()
    part.Color = _G.HitboxColor
    part.Material = Enum.Material.ForceField
    part.Transparency = _G.ShowHitboxVisual and 0.3 or 1
    part.Anchored = true
    part.CanCollide = false
    part.CastShadow = false
    part.Parent = Hitboxes

    local outline = Instance.new("SelectionBox")
    outline.Adornee = part
    outline.Color3 = _G.HitboxOutlineColor
    outline.LineThickness = _G.OutlineThickness
    outline.Transparency = 0.1
    outline.Visible = _G.ShowOutline and _G.ShowHitboxVisual
    outline.Parent = part

    return part
end

local function UpdateHitboxPosition(part, queryHitbox)
    if part and queryHitbox then
        part.CFrame = queryHitbox.CFrame * CFrame.new(0, 0, _G.HitboxOffset)
        part.Size = GetHitboxSize()
        part.Color = _G.HitboxColor
        part.Transparency = _G.ShowHitboxVisual and 0.3 or 1
        local outline = part:FindFirstChildOfClass("SelectionBox")
        if outline then
            outline.Color3 = _G.HitboxOutlineColor
            outline.LineThickness = _G.OutlineThickness
            outline.Visible = _G.ShowOutline and _G.ShowHitboxVisual
        end
    end
end

local function ClearKillerHitbox(Killer)
    local data = _G.KillerHitboxData[Killer]
    if data then
        if data.part then
            data.part:Destroy()
        end
        if data.connection then
            data.connection:Disconnect()
        end
        _G.KillerHitboxData[Killer] = nil
    end
end

local function UpdateAllHitboxVisuals()
    for killer, data in pairs(_G.KillerHitboxData) do
        if data.part and data.part.Parent then
            data.part.Color = _G.HitboxColor
            data.part.Size = GetHitboxSize()
            data.part.Transparency = _G.ShowHitboxVisual and 0.3 or 1
            local outline = data.part:FindFirstChildOfClass("SelectionBox")
            if outline then
                outline.Color3 = _G.HitboxOutlineColor
                outline.LineThickness = _G.OutlineThickness
                outline.Visible = _G.ShowOutline and _G.ShowHitboxVisual
            end
        end
    end
end

local function StartAttack(Killer, queryHitbox, Track)
    ClearKillerHitbox(Killer)

    local visualPart = CreateHitboxVisual()
    UpdateHitboxPosition(visualPart, queryHitbox)

    local updateConnection
    updateConnection = RunService.Heartbeat:Connect(function()
        if not _G.AutoBlockEnabled then
            updateConnection:Disconnect()
            return
        end
        if visualPart and visualPart.Parent and queryHitbox and queryHitbox.Parent then
            UpdateHitboxPosition(visualPart, queryHitbox)
        else
            updateConnection:Disconnect()
        end
    end)

    _G.KillerHitboxData[Killer] = {
        part = visualPart,
        connection = updateConnection
    }

    if Track then
        Track.Stopped:Once(function()
            ClearKillerHitbox(Killer)
        end)
        Track.Destroying:Once(function()
            ClearKillerHitbox(Killer)
        end)
    end

    local LocalChar = LocalPlayer.Character
    if not LocalChar or LocalChar.Parent ~= SurvivorsFolder then
        return
    end

    local LocalQuery = LocalChar:FindFirstChild("QueryHitbox")
    if not LocalQuery then return end

    local now = tick()
    if now - LastBlockTime < BLOCK_COOLDOWN then return end

    local isC00lkidd = Killer.Name:lower():find("c00lkidd") or Killer.Name:lower():find("coolkidd")

    local hitboxSize = GetHitboxSize()

    if isC00lkidd then
        OverlapParams.FilterDescendantsInstances = {LocalQuery}

        local Part = Instance.new("Part")
        Part.Name = "KillerDetectHitbox"
        Part.Size = hitboxSize
        Part.CFrame = queryHitbox.CFrame * CFrame.new(0, 0, _G.HitboxOffset)
        Part.CanCollide = false
        Part.Anchored = true
        Part.CastShadow = false
        Part.Material = Enum.Material.ForceField
        Part.Transparency = 1
        Part.Parent = Hitboxes
        Debris:AddItem(Part, 0.4)

        local hits = workspace:GetPartsInPart(Part, OverlapParams)
        if #hits > 0 then
            pressBlock()
            LastBlockTime = tick()
        end
        return
    end

    local maxAttempts = _G.AntiBaitEnabled and 18 or 6
    local lastHitDetected = false

    for i = 1, maxAttempts do
        if not _G.AutoBlockEnabled then break end
        if not LocalChar.Parent or LocalChar.Parent ~= SurvivorsFolder then break end

        OverlapParams.FilterDescendantsInstances = {LocalQuery}

        local Part = Instance.new("Part")
        Part.Name = "KillerDetectHitbox"
        Part.Size = hitboxSize
        Part.CFrame = queryHitbox.CFrame * CFrame.new(0, 0, _G.HitboxOffset)
        Part.CanCollide = false
        Part.Anchored = true
        Part.CastShadow = false
        Part.Material = Enum.Material.ForceField
        Part.Transparency = 1
        Part.Parent = Hitboxes
        Debris:AddItem(Part, 0.4)

        local hits = workspace:GetPartsInPart(Part, OverlapParams)
        local hitNow = #hits > 0

        if _G.AntiBaitEnabled then
            lastHitDetected = hitNow
            if i == maxAttempts and lastHitDetected then
                pressBlock()
                LastBlockTime = tick()
            end
        else
            if hitNow then
                pressBlock()
                LastBlockTime = tick()
                break
            end
        end
        task.wait(0.015)
    end
end

local function HandleKiller(Killer)
    if not Players:GetPlayerFromCharacter(Killer) then return end
    local humanoid = Killer:FindFirstChildOfClass("Humanoid")
    local queryHitbox = Killer:FindFirstChild("QueryHitbox")
    local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
    if not (animator and queryHitbox) then return end

    local soundConnections = {}
    local function OnSoundAdded(Sound)
        if not Sound:IsA("Sound") then return end
        local id = tostring(Sound.SoundId):match("%d+")
        if not id or not GlobalAttackSoundIDs[id] then return end

        local playedConn = Sound.Played:Connect(function()
            if not _G.AutoBlockEnabled then return end
            StartAttack(Killer, queryHitbox, Sound)
        end)

        local stoppedConn = Sound.Stopped:Connect(function()
            ClearKillerHitbox(Killer)
        end)

        table.insert(soundConnections, playedConn)
        table.insert(soundConnections, stoppedConn)

        if Sound.IsPlaying then
            task.spawn(function()
                if _G.AutoBlockEnabled then
                    StartAttack(Killer, queryHitbox, Sound)
                end
            end)
        end
    end

    for _, sound in ipairs(Killer:GetDescendants()) do
        OnSoundAdded(sound)
    end

    local descendantConn = Killer.DescendantAdded:Connect(OnSoundAdded)
    table.insert(soundConnections, descendantConn)

    local function cleanupSounds()
        for _, conn in ipairs(soundConnections) do
            conn:Disconnect()
        end
        soundConnections = {}
    end

    local connection = animator.AnimationPlayed:Connect(function(Track)
        if not _G.AutoBlockEnabled then
            connection:Disconnect()
            return
        end

        local id = GetID(Track.Animation.AnimationId)
        local isMatch = false

        if id and GlobalAttackIDs[id] then
            isMatch = true
        else
            local animType = GetAnimationType(Track.Animation.AnimationId)
            if animType and table.find(BlockableAttacks, animType:lower()) then
                isMatch = true
            end
        end

        if not isMatch then return end

        StartAttack(Killer, queryHitbox, Track)
    end)

    local function cleanup()
        cleanupSounds()
        connection:Disconnect()
        ClearKillerHitbox(Killer)
    end

    Killer.AncestryChanged:Connect(function()
        if not Killer.Parent then
            cleanup()
        end
    end)

    table.insert(_G.AutoBlockConnections, {
        Disconnect = cleanup
    })
end

local function EnableAutoBlock()
    if _G.AutoBlockEnabled then return end
    _G.AutoBlockEnabled = true
    if _G.AutoBlockConnections then
        for _, con in ipairs(_G.AutoBlockConnections) do
            pcall(con.Disconnect, con)
        end
        _G.AutoBlockConnections = {}
    end
    if KillersFolder then
        for _, killer in ipairs(KillersFolder:GetChildren()) do
            HandleKiller(killer)
        end
        local childCon = KillersFolder.ChildAdded:Connect(HandleKiller)
        table.insert(_G.AutoBlockConnections, childCon)
    end

    if _G.AntiBaitToggle then
        _G.AntiBaitToggle:SetEnabled(true)
    end

    WindUI:Notify({
        Title = "AutoBlock",
        Content = "Enabled",
        Icon = "check",
        Duration = 2
    })
end

local function DisableAutoBlock()
    if not _G.AutoBlockEnabled then return end
    _G.AutoBlockEnabled = false
    if _G.AutoBlockConnections then
        for _, con in ipairs(_G.AutoBlockConnections) do
            pcall(con.Disconnect, con)
        end
        _G.AutoBlockConnections = {}
    end

    for killer, data in pairs(_G.KillerHitboxData) do
        if data.part then
            data.part:Destroy()
        end
        if data.connection then
            data.connection:Disconnect()
        end
    end
    _G.KillerHitboxData = {}

    if _G.AntiBaitToggle then
        _G.AntiBaitToggle:SetEnabled(false)
        if _G.AntiBaitEnabled then
            _G.AntiBaitEnabled = false
            _G.AntiBaitToggle:SetValue(false)
        end
    end

    WindUI:Notify({
        Title = "AutoBlock",
        Content = "Disabled",
        Icon = "x",
        Duration = 2
    })
end

local FPS = 0
