local AllAnimations = {}
local function LoadAnimations()
    local assets = ReplicatedStorage:FindFirstChild("Assets")
    if not assets then return end
    for _, folder in pairs({assets:FindFirstChild("Killers"), assets:FindFirstChild("Survivors"), assets:FindFirstChild("Skins")}) do
        if folder then
            for _, child in folder:GetDescendants() do
                if child:IsA("ModuleScript") and child.Name == "Config" then
                    local ok, data = pcall(require, child)
                    if ok and data and data.Animations then
                        AllAnimations[data.DisplayName] = data.Animations
                    end
                end
            end
        end
    end
end
LoadAnimations()

local function GetAnimationType(animationId)
    if not animationId then return nil end
    local idStr = tostring(animationId)
    for _, charAnims in pairs(AllAnimations) do
        for animType, animId in pairs(charAnims) do
            if type(animId) == "string" and animId:find(idStr) then return animType
            elseif type(animId) == "table" then
                for _, subId in ipairs(animId) do
                    if tostring(subId):find(idStr) then return animType end
                end
            end
        end
    end
    return nil
end

