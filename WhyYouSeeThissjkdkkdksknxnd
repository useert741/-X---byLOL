local function playEmote(animId, soundId, volume, looped, remoteName, effectAsset)
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return nil end
    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do track:Stop() end
    for _, sound in ipairs(rootPart:GetChildren()) do if sound:IsA("Sound") then sound:Stop(); sound:Destroy() end end
    for _, child in ipairs(char:GetChildren()) do if child.Name:match("Emote") or child.Name=="PlayerEmoteVFX" then child:Destroy() end end
    humanoid.PlatformStand = true
    humanoid.JumpPower = 0
    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(100000,100000,100000)
    bodyVelocity.Velocity = Vector3.zero
    bodyVelocity.Parent = rootPart
    local animation = Instance.new("Animation")
    animation.AnimationId = animId
    local track = humanoid:LoadAnimation(animation)
    track:Play()
    local sound = Instance.new("Sound")
    sound.SoundId = soundId
    sound.Volume = volume or 0.5
    sound.Looped = looped or false
    sound.Parent = rootPart
    sound:Play()
    if effectAsset then pcall(function() local effect = game:GetService("ReplicatedStorage"):FindFirstChild(effectAsset); if effect then local clone = effect:Clone(); clone.Name="PlayerEmoteVFX"; if char.PrimaryPart then clone.CFrame = char.PrimaryPart.CFrame * CFrame.new(0,-1,-0.3) end; local weld = Instance.new("WeldConstraint"); weld.Part0 = char.PrimaryPart; weld.Part1 = clone; weld.Parent = clone; clone.Parent = char; clone.CanCollide = false end end) end
    if remoteName then pcall(function() local remote = game:GetService("ReplicatedStorage"):WaitForChild("Modules"):WaitForChild("Network"):WaitForChild("RemoteEvent"); remote:FireServer("PlayEmote","Animations",remoteName) end) end
    local function cleanup() pcall(function() if bodyVelocity and bodyVelocity.Parent then bodyVelocity:Destroy() end; if sound and sound.Parent then sound:Stop(); sound:Destroy() end; if track and track.IsPlaying then track:Stop() end; humanoid.PlatformStand = false; humanoid.JumpPower = 50; for _, child in ipairs(char:GetChildren()) do if child.Name:match("Emote") or child.Name=="PlayerEmoteVFX" then child:Destroy() end end end) end
    track.Stopped:Connect(cleanup)
    return {track=track, sound=sound, bodyVelocity=bodyVelocity, cleanup=cleanup}
end
local currentEmote = nil
local function createEmoteToggle(text, animId, soundId, volume, looped, remoteName, effectAsset) return function(state) if state then if currentEmote then currentEmote.cleanup() end; currentEmote = playEmote(animId, soundId, volume, looped, remoteName, effectAsset); Library:Notify({Title=text, Description="Playing", Time=1}) else if currentEmote then currentEmote.cleanup(); currentEmote = nil; Library:Notify({Title=text, Description="Stopped", Time=1}) end end end end
