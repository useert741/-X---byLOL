local CFSpeed = 50
local CFLoop = nil
local function StartCFly()
    local char = localPlayer.Character; if not char then return end
    local hum = char:FindFirstChildOfClass('Humanoid'); local head = char:WaitForChild("Head")
    if not hum or not head then return end
    hum.PlatformStand = true; head.Anchored = true
    if CFLoop then CFLoop:Disconnect(); CFLoop = nil end
    CFLoop = game:GetService("RunService").Heartbeat:Connect(function(dt)
        if not char or not hum or not head then if CFLoop then CFLoop:Disconnect(); CFLoop = nil end return end
        local moveDir = hum.MoveDirection * (CFSpeed * dt)
        local headCF = head.CFrame
        local cam = workspace.CurrentCamera; local camCF = cam.CFrame
        local off = headCF:ToObjectSpace(camCF).Position
        camCF = camCF * CFrame.new(-off.X, -off.Y, -off.Z + 1)
        local camPos = camCF.Position; local headPos = headCF.Position
        local objVel = CFrame.new(camPos, Vector3.new(headPos.X, camPos.Y, headPos.Z)):VectorToObjectSpace(moveDir)
        head.CFrame = CFrame.new(headPos) * (camCF - camPos) * CFrame.new(objVel)
    end)
end
local function StopCFly()
    if CFLoop then CFLoop:Disconnect(); CFLoop = nil end
    local char = localPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass('Humanoid'); local head = char:FindFirstChild("Head")
        if hum then hum.PlatformStand = false end
        if head then head.Anchored = false end
    end
end
