local repairMode = "Custom Mode[自调模式]"
local repairInterval = 1
local autoRepairEnabled = false
local repairThread = nil
local quickAutoRepairEnabled = false
local quickRepairInterval = 1.25
local quickRepairThread = nil
local function getNearestGenerator()
    local char = localPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local rootPos = char.HumanoidRootPart.Position
    local mapFolder = workspace:FindFirstChild("Map")
    if not mapFolder then return nil end
    local ingame = mapFolder:FindFirstChild("Ingame")
    if not ingame then return nil end
    local map = ingame:FindFirstChild("Map")
    if not map then return nil end
    local nearest, nearestDist = nil, math.huge
    for _, gen in ipairs(map:GetChildren()) do
        if gen:IsA("Model") and gen.Name == "Generator" and gen:FindFirstChild("Remotes") and gen.Remotes:FindFirstChild("RE") then
            local part = gen:FindFirstChild("Main") or gen:FindFirstChild("PrimaryPart")
            if part then
                local dist = (part.Position - rootPos).Magnitude
                if dist < nearestDist then nearestDist = dist; nearest = gen end
            end
        end
    end
    return nearest
end
local function fireRepairRemote(gen) if gen then pcall(function() gen.Remotes.RE:FireServer() end) end end
local function autoRepairLoop()
    while autoRepairEnabled do
        if localPlayer.PlayerGui:FindFirstChild("PuzzleUI") then
            local delay = repairInterval
            if repairMode == "Danger Mode[危险模式]" then delay = 1 elseif repairMode == "Safe Mode[安全模式]" then delay = 3 end
            local gen = getNearestGenerator()
            if gen then fireRepairRemote(gen) end
            task.wait(delay)
        else task.wait(0.1) end
    end
end
local function quickAutoRepairLoop()
    while quickAutoRepairEnabled do
        local gen = getNearestGenerator()
        if gen then fireRepairRemote(gen) end
        task.wait(quickRepairInterval)
    end
end
