local function isKillerFacingPlayer(killerModel, myRoot)
    if not BlockSettings.FacingCheck then return true end
    if not killerModel or not myRoot then return true end
    local killerHead = killerModel:FindFirstChild("Head")
    local killerCF = killerHead and killerHead.CFrame or (killerModel:FindFirstChild("HumanoidRootPart") and killerModel.HumanoidRootPart.CFrame)
    if not killerCF then return true end
    local killerPos = killerCF.Position
    local killerForward = killerCF.LookVector
    local toPlayer = (myRoot.Position - killerPos).Unit
    local dot = killerForward:Dot(toPlayer)
    if BlockSettings.LooseFacing then return dot > -0.3 else return dot > 0 end
end
