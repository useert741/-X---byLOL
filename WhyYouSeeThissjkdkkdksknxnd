Old__namecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Args = { ... }
    local Method = getnamecallmethod()
    if not checkcaller() and typeof(Self) == "Instance" then
        if Method == "InvokeServer" or Method == "FireServer" then
            if tostring(Self) == "RF" then
                if Args[1] == "enter" then remoteCheck = true
                elseif Args[1] == "leave" then remoteCheck = false end
            elseif tostring(Self) == "RE" then remoteTimestamp = os.clock() end
        end
    end
    return Old__namecall(Self, unpack(Args))
end)

