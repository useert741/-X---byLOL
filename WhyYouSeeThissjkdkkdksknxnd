local AnimPresets = {
    ["Slasher"] = { Idle = "116050994905421", Walk = "93622022596108", Run = "93054787145505" },
    ["c00lkidd"] = { Idle = "18885903667", Walk = "18885906143", Run = "96571077893813" },
    ["John Doe"] = { Idle = "105880087711722", Walk = "81193817424328", Run = "132653655520682" },
    ["Noli"] = { Idle = "83465205704188", Walk = "109700476007435", Run = "117451341682452" },
    ["1x1x1x1"] = { Idle = "138754221537146", Walk = "109130982296927", Run = "106485518413331" },
    ["Nosferatu"] = { Idle = "70639889347646", Walk = "125580704385106", Run = "82983377044738" }
}
local presetNames = {}
for name, _ in pairs(AnimPresets) do table.insert(presetNames, name) end
table.sort(presetNames)
local customAnimData = { active = false, preset = nil, tracks = { Idle = nil, Walk = nil, Run = nil }, connection = nil }
local function getHumanoidAndAnimator()
    local char = localPlayer.Character
    if not char then return nil, nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return nil, nil end
    local animator = hum:FindFirstChildOfClass("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = hum
    end
    return hum, animator
end
local function stopCustomAnimations()
    if customAnimData.connection then
        customAnimData.connection:Disconnect()
        customAnimData.connection = nil
    end
    for animType, track in pairs(customAnimData.tracks) do
        if track then track:Stop(); track:Destroy(); customAnimData.tracks[animType] = nil end
    end
    customAnimData.active = false
end
local function updateAnimation()
    local hum, animator = getHumanoidAndAnimator()
    if not hum or not animator or not customAnimData.preset then return end
    local speed = hum.MoveDirection.Magnitude
    local targetAnim = "Idle"
    if speed > 0.5 then targetAnim = hum.WalkSpeed > 20 and "Run" or "Walk" end
    local targetTrack = customAnimData.tracks[targetAnim]
    if targetTrack and not targetTrack.IsPlaying then
        for animType, track in pairs(customAnimData.tracks) do
            if track and track ~= targetTrack then track:Stop() end
        end
        targetTrack:Play()
    elseif not targetTrack then
        stopCustomAnimations()
        customAnimData.active = true
        customAnimData.preset = _G.LastSelectedPreset
        local preset = AnimPresets[_G.LastSelectedPreset]
        if not preset then return end
        for _, animType in ipairs({"Idle", "Walk", "Run"}) do
            local animId = preset[animType]
            if animId and animId ~= "" then
                local animation = Instance.new("Animation")
                animation.AnimationId = "rbxassetid://" .. animId
                local track = animator:LoadAnimation(animation)
                track.Priority = Enum.AnimationPriority.Movement
                customAnimData.tracks[animType] = track
            end
        end
        local newTargetAnim = hum.MoveDirection.Magnitude > 0.5 and (hum.WalkSpeed > 20 and "Run" or "Walk") or "Idle"
        local newTrack = customAnimData.tracks[newTargetAnim]
        if newTrack then newTrack:Play() end
    end
end
local function applyPreset(presetName)
    local preset = AnimPresets[presetName]
    if not preset then return end
    local hum, animator = getHumanoidAndAnimator()
    if not hum or not animator then return end
    stopCustomAnimations()
    customAnimData.active = true
    customAnimData.preset = presetName
    for _, animType in ipairs({"Idle", "Walk", "Run"}) do
        local animId = preset[animType]
        if animId and animId ~= "" then
            local animation = Instance.new("Animation")
            animation.AnimationId = "rbxassetid://" .. animId
            local track = animator:LoadAnimation(animation)
            track.Priority = Enum.AnimationPriority.Movement
            customAnimData.tracks[animType] = track
        end
    end
    local speed = hum.MoveDirection.Magnitude
    local targetAnim = "Idle"
    if speed > 0.5 then targetAnim = hum.WalkSpeed > 20 and "Run" or "Walk" end
    local targetTrack = customAnimData.tracks[targetAnim]
    if targetTrack then targetTrack:Play() end
    customAnimData.connection = game:GetService("RunService").RenderStepped:Connect(updateAnimation)
    Library:Notify({ Title = "Animation", Description = "Applied " .. presetName .. " animations", Time = 2 })
end
local function resetAnimations()
    stopCustomAnimations()
    _G.LastSelectedPreset = nil
    Library:Notify({ Title = "Animation Reset", Description = "Restored to default animations", Time = 2 })
end
localPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    if _G.LastSelectedPreset and AnimPresets[_G.LastSelectedPreset] then
        applyPreset(_G.LastSelectedPreset)
    end
end)
