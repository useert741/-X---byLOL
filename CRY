local function ExtendHitbox(s, t)
    if not shared.emergency_stop then shared.emergency_stop = false end
    local d = s * 6
    local st = tick()
    if shared.emergency_stop then shared.emergency_stop = false end
    repeat
        svc.Run.Heartbeat:Wait()
        local vel = nil
        while not (lp.Character and lp.Character.Parent and lp.Character.HumanoidRootPart and lp.Character.HumanoidRootPart.Parent) do
            svc.Run.Heartbeat:Wait()
        end
        vel = lp.Character.HumanoidRootPart.Velocity
        lp.Character.HumanoidRootPart.Velocity = vel * d + (lp.Character.HumanoidRootPart.CFrame.LookVector * d)
        svc.Run.RenderStepped:Wait()
        if (lp.Character and lp.Character.Parent and lp.Character.HumanoidRootPart and lp.Character.HumanoidRootPart.Parent) then
            lp.Character.HumanoidRootPart.Velocity = vel
        end
    until tick() - st > tonumber(t) or shared.emergency_stop
    if shared.emergency_stop then shared.emergency_stop = false end
end

local function StopExtendingHitbox()
