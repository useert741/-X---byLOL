local function getNearest()
    if not HRP then return end
    local pf = workspace:FindFirstChild("Players")
    local kf = pf and pf:FindFirstChild("Killers")
    local sf = pf and pf:FindFirstChild("Survivors")
    if not kf then return end
    local cl, dist = nil, math.huge
    for _, m in ipairs(kf:GetChildren()) do
        if sf and m:IsDescendantOf(sf) then continue end
        if m == lp.Character then continue end
        local r = m:FindFirstChild("HumanoidRootPart")
        local h = m:FindFirstChildOfClass("Humanoid")
        if r and h and h.Health > 0 then
            local d = (r.Position - HRP.Position).Magnitude
            if d < dist then dist = d; cl = r end
        end
    end
    return cl
end

local motionData = {}
local function getMotion(hp)
    local now = tick()
    local pos = hp.Position
    local d = motionData[hp]
    if not d then
        motionData[hp] = { lastPos = pos, lastTime = now, velocity = Vector3.zero, accel = Vector3.zero }
        return Vector3.zero, Vector3.zero
    end
    local dt = now - d.lastTime
    if dt <= 0 then return d.velocity, d.accel end
    local vel = (pos - d.lastPos) / dt
    local acc = (vel - d.velocity) / dt
    d.lastPos = pos
    d.lastTime = now
    d.accel = acc
    d.velocity = vel
    return vel, acc
end

local pingSamples = {}
local function getPing()
    local ok, st = pcall(function() return game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue() end)
    local raw = (ok and st or 100) / 1000
    table.insert(pingSamples, raw)
    if #pingSamples > 5 then table.remove(pingSamples, 1) end
    local sum = 0
    for _, v in ipairs(pingSamples) do sum = sum + v end
    return sum / #pingSamples
end

local function predict(hp)
    local vel, acc = getMotion(hp)
    local pos = hp.Position
    local speed = vel.Magnitude
    if antiBait then
        local m = hp.Parent
        if m and killerSpeeds[m.Name] then
            local ms = killerSpeeds[m.Name].run + 2
            if speed > ms then vel = vel.Unit * ms; speed = ms end
        end
    end
    local ping = getPing()
    local dist = HRP and (hp.Position - HRP.Position).Magnitude or 0
    local ds = dist * 0.003
    local lead
    if predMode == "Velocity" then
        lead = predValue + ds
    elseif predMode == "Ping" then
        lead = ping * predValue + ds
    elseif predMode == "Look" then
        return pos + hp.CFrame.LookVector * (speed * predValue)
    elseif predMode == "LookPing" then
        return pos + hp.CFrame.LookVector * (speed * ping)
    else
        lead = predValue
    end
    if HRP and speed > 1 then
        local toK = (hp.Position - HRP.Position).Unit
        local strafe = math.abs(vel.Unit:Dot(Vector3.new(-toK.Z, 0, toK.X)))
        if strafe > 0.5 then lead = lead + strafe * 0.06 end
    end
    if speed < 0.5 then return pos end
    local ac = acc * lead * lead * 0.5
    local am = ac.Magnitude
    if am > speed * 0.4 then ac = ac.Unit * (speed * 0.4) end
    return pos + vel * lead + ac
end

