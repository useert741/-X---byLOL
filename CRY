local function isPointInBox(point, centerCF, forward, up, right, size)
    local localPos = centerCF:PointToObjectSpace(point)
    local half = size / 2
    return math.abs(localPos.X) <= half.X and math.abs(localPos.Y) <= half.Y and math.abs(localPos.Z) <= half.Z
end

