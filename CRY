local function performBackstab(m,t,sl) if not m or not m.Parent then return false end local c=lp.Character if not c then return false end local r=c:FindFirstChild("HumanoidRootPart") local kr=m:FindFirstChild("HumanoidRootPart") if not r or not kr then return false end local mode=BackstabSettings.Mode local bo=-kr.CFrame.LookVector*BackstabSettings.Offset local tp=kr.Position+bo+Vector3.new(0,0.5,0) local tcf=CFrame.new(tp,kr.Position) local scf=r.CFrame local st=BackstabSettings.TeleportSmoothness local stt=BackstabSettings.TeleportDuration/st for i=1,st do r.CFrame=scf:Lerp(tcf,i/st) task.wait(stt) end r.CFrame=tcf if mode=="Blatant" then if sl then BackstabSettings.Active=true BackstabSettings.ActiveKiller=m BackstabSettings.ActiveTrack=t startBackstabLoop(m,t) end end return true end
