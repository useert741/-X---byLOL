    local gcf = CFrame.lookAt(HRP.Position, aimPos)
    local isMoving = HRP.AssemblyLinearVelocity.Magnitude > 0.5
    local sp = isMoving and math.max(smoothSpeed, 20) or smoothSpeed
    local alpha = 1 - math.exp(-sp * dt)
    HRP.CFrame = HRP.CFrame:Lerp(gcf, alpha)
end)

