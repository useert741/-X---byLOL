local function stopBackstab()
    if BackstabSettings.LoopConnection then
        BackstabSettings.LoopConnection:Disconnect()
        BackstabSettings.LoopConnection = nil
    end
    BackstabSettings.Active = false
    BackstabSettings.ActiveKiller = nil
    BackstabSettings.ActiveTrack = nil
    local c = lp.Character
    if c then
        local h = c:FindFirstChildOfClass("Humanoid")
        if h then h.AutoRotate = true end
    end
end

local function startBackstabLoop(m, t)
    if BackstabSettings.LoopConnection then BackstabSettings.LoopConnection:Disconnect() end
    local c = lp.Character
    if not c then stopBackstab(); return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if h then h.AutoRotate = false end
    BackstabSettings.LoopConnection = svc.Run.RenderStepped:Connect(function()
        if not BackstabSettings.Active then stopBackstab(); return end
        if not m or not m.Parent then stopBackstab(); return end
        local mc = lp.Character
        if not mc or not mc.Parent then stopBackstab(); return end
        local r = mc:FindFirstChild("HumanoidRootPart")
        local kr = m:FindFirstChild("HumanoidRootPart")
        if not r or not kr then stopBackstab(); return end
        local bo = -kr.CFrame.LookVector * BackstabSettings.Offset
        local tp = kr.Position + bo + Vector3.new(0, 0.5, 0)
        r.CFrame = CFrame.new(tp, kr.Position)
    end)
    if t and t.Parent then
        local cn
        cn = t.Stopped:Connect(function()
            cn:Disconnect()
            stopBackstab()
        end)
        local ac
        ac = t.AncestryChanged:Connect(function()
            if not t.Parent then
                ac:Disconnect()
                stopBackstab()
            end
        end)
    else
        task.delay(BackstabSettings.TeleportDuration + 0.5, function()
            if BackstabSettings.Active and BackstabSettings.ActiveTrack == t then
                stopBackstab()
            end
        end)
    end
end

local function performBackstab(m, t, sl)
    if not m or not m.Parent then return false end
    local c = lp.Character
    if not c then return false end
    local r = c:FindFirstChild("HumanoidRootPart")
    local kr = m:FindFirstChild("HumanoidRootPart")
    if not r or not kr then return false end
    local mode = BackstabSettings.Mode
    local bo = -kr.CFrame.LookVector * BackstabSettings.Offset
    local tp = kr.Position + bo + Vector3.new(0, 0.5, 0)
    local tcf = CFrame.new(tp, kr.Position)
    local scf = r.CFrame
    local st = BackstabSettings.TeleportSmoothness
    local stt = BackstabSettings.TeleportDuration / st
    for i = 1, st do
        r.CFrame = scf:Lerp(tcf, i / st)
        task.wait(stt)
    end
    r.CFrame = tcf
    if mode == "Blatant" then
        if sl then
            BackstabSettings.Active = true
            BackstabSettings.ActiveKiller = m
            BackstabSettings.ActiveTrack = t
            startBackstabLoop(m, t)
        end
    end
    return true
end

local function getNearestKillerForBackstab()
    local ks = getKillersFolder()
    if not ks then return nil end
    local c = lp.Character
    if not c then return nil end
    local r = c:FindFirstChild("HumanoidRootPart")
    if not r then return nil end
    local near, nd = nil, math.huge
    for _, k in ipairs(ks:GetChildren()) do
        if k:IsA("Model") and k:FindFirstChild("HumanoidRootPart") and k:GetAttribute("IsFakeNoli") ~= true then
            local d = (k.HumanoidRootPart.Position - r.Position).Magnitude
            if d <= BackstabSettings.Distance and d < nd then
                nd = d
                near = k
            end
        end
    end
    return near
end

