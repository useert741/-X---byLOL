local function UpdateESP() local mf=workspace:FindFirstChild("Map") if not mf or not mf:FindFirstChild("Ingame") then for i=#PlayerESPData,1,-1 do RemoveESP(PlayerESPData[i].model) end for i=#ObjectESPData,1,-1 do RemoveESP(ObjectESPData[i].model) end for m in pairs(TracerData) do RemoveTracerBeam(m) end return end local ing=mf.Ingame local pf=workspace:FindFirstChild("Players") if pf then local ks=pf:FindFirstChild("Killers") if ks then for _,k in ipairs(ks:GetChildren()) do if k==lp.Character then continue end if IsRagdoll(k) then RemoveESP(k) RemoveTracerBeam(k) continue end local p=game:GetService("Players"):GetPlayerFromCharacter(k) if not p or IsSpectating(p) then RemoveESP(k) RemoveTracerBeam(k) continue end if ESPSettings.killerESP and not k:FindFirstChild("TAOWARE_Highlight") and k:FindFirstChild("HumanoidRootPart") then CreateESP(k,ESPSettings.killerColor,false,false,false,false,false,false,false,false,true) elseif not ESPSettings.killerESP then RemoveESP(k) end if ESPSettings.killerTracers and k:FindFirstChild("HumanoidRootPart") then CreateTracerBeam(k,k.HumanoidRootPart,ESPSettings.killerColor) else RemoveTracerBeam(k) end end end local sv=pf:FindFirstChild("Survivors") if sv then for _,s in ipairs(sv:GetChildren()) do if s==lp.Character then continue end if IsRagdoll(s) then RemoveESP(s) RemoveTracerBeam(s) continue end local p=game:GetService("Players"):GetPlayerFromCharacter(s) if not p or IsSpectating(p) then RemoveESP(s) RemoveTracerBeam(s) continue end if ESPSettings.playerESP and not s:FindFirstChild("TAOWARE_Highlight") and s:FindFirstChild("HumanoidRootPart") then CreateESP(s,ESPSettings.survivorColor,false,false,false,false,false,false,false,false,false) elseif not ESPSettings.playerESP then RemoveESP(s) end if ESPSettings.survivorTracers and s:FindFirstChild("HumanoidRootPart") then CreateTracerBeam(s,s.HumanoidRootPart,ESPSettings.survivorColor) else RemoveTracerBeam(s) end end end end if ing:FindFirstChild("Map") then for _,g in ipairs(ing.Map:GetChildren()) do if g:IsA("Model") and g.Name:lower():find("generator") and g.Name~="FakeGenerator" then if IsRagdoll(g) then RemoveESP(g) RemoveTracerBeam(g) continue end local p=g:FindFirstChild("Progress") if ESPSettings.generatorESP and p and p.Value<100 and not g:FindFirstChild("TAOWARE_Highlight") then CreateESP(g,ESPSettings.generatorColor,true,false,false,false,false,false,false,false) elseif(not ESPSettings.generatorESP or(p and p.Value>=100)) then RemoveESP(g) end if ESPSettings.generatorTracers and p and p.Value<100 then local part=GetGeneratorPart(g) if part then CreateTracerBeam(g,part,ESPSettings.generatorColor) end else RemoveTracerBeam(g) end end end for _,i in ipairs(ing.Map:GetDescendants()) do if i.Name=="ItemRoot" and i.Parent and i.Parent:IsA("Model") then local im=i.Parent if ESPSettings.itemESP and not im:FindFirstChild("TAOWARE_Highlight") then CreateESP(im,ESPSettings.itemColor,false,true,false,false,false,false,false,false) elseif not ESPSettings.itemESP then RemoveESP(im) end if ESPSettings.itemTracers and i:IsA("BasePart") then CreateTracerBeam(im,i,ESPSettings.itemColor) else RemoveTracerBeam(im) end end end end for _,p in ipairs(ing:GetChildren()) do if p.Name=="Pizza" and p:IsA("BasePart") then if ESPSettings.pizzaEsp and not p:FindFirstChild("TAOWARE_Highlight") then CreateESP(p,ESPSettings.pizzaColor,false,false,true,false,false,false,false,false) elseif not ESPSettings.pizzaEsp then RemoveESP(p) end if ESPSettings.pizzaTracers then CreateTracerBeam(p,p,ESPSettings.pizzaColor) else RemoveTracerBeam(p) end end end for _,d in ipairs(ing:GetChildren()) do if d:IsA("Model") and table.find(DummyNames,d.Name) then if ESPSettings.pizzaDeliveryEsp and not d:FindFirstChild("TAOWARE_Highlight") then local hr=d:FindFirstChild("HumanoidRootPart") if hr then CreateESP(d,ESPSettings.pizzaDeliveryColor,false,false,false,true,false,false,false,false) end elseif not ESPSettings.pizzaDeliveryEsp then RemoveESP(d) end if ESPSettings.pizzaDeliveryTracers then local hr=d:FindFirstChild("HumanoidRootPart") if hr then CreateTracerBeam(d,hr,ESPSettings.pizzaDeliveryColor) end else RemoveTracerBeam(d) end end end for _,z in ipairs(ing:GetChildren()) do if z.Name=="Zombie" and z:IsA("Model") then if ESPSettings.zombieEsp and not z:FindFirstChild("TAOWARE_Highlight") then local hr=z:FindFirstChild("HumanoidRootPart") if hr then CreateESP(z,ESPSettings.zombieColor,false,false,false,false,true,false,false,false) end elseif not ESPSettings.zombieEsp then RemoveESP(z) end if ESPSettings.zombieTracers then local hr=z:FindFirstChild("HumanoidRootPart") if hr then CreateTracerBeam(z,hr,ESPSettings.zombieColor) end else RemoveTracerBeam(z) end end end for _,t in ipairs(ing:GetChildren()) do if t.Name=="TaphTripwire" and t:IsA("BasePart") then if ESPSettings.taphTripwireEsp and not t:FindFirstChild("TAOWARE_Highlight") then CreateESP(t,ESPSettings.tripwireColor,false,false,false,false,false,true,false,false) elseif not ESPSettings.taphTripwireEsp then RemoveESP(t) end end end for _,m in ipairs(ing:GetChildren()) do if m.Name=="SubspaceTripmine" and m:IsA("Model") then if ESPSettings.subspaceBoxEsp and not m:FindFirstChild("TAOWARE_Highlight") then CreateESP(m,ESPSettings.subspaceBoxColor,false,false,false,false,false,false,true,false) elseif not ESPSettings.subspaceBoxEsp then RemoveESP(m) end end end for _,r in ipairs(ing:GetChildren()) do if r.Name=="TwoTimeRespawn" and r:IsA("BasePart") then if ESPSettings.twoTimeRespawnEsp and not r:FindFirstChild("TAOWARE_Highlight") then CreateESP(r,ESPSettings.respawnColor,false,false,false,false,false,false,false,true) elseif not ESPSettings.twoTimeRespawnEsp then RemoveESP(r) end end end end
