local hitboxUILoaded = false
local function loadHitboxUI()
    if hitboxUILoaded then return end
    hitboxUILoaded = true
    local Players = game:GetService("Players")
    local RunService = svc.Run
    local CoreGui = game:GetService("CoreGui")
    local Workspace = workspace
    local speaker = Players.LocalPlayer
    local HitboxGay = false
    local loopRunning = false
    local player = Players.LocalPlayer

    local function isAnimationPlaying(ids)
        local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        local a = h and h:FindFirstChildOfClass("Animator")
        if not a then return false end
        if typeof(ids) ~= "table" then ids = { ids } end
        for _, t in ipairs(a:GetPlayingAnimationTracks()) do
            local id = t.Animation.AnimationId:match("%d+")
            for _, i in ipairs(ids) do
                if id == tostring(i) then return true end
            end
        end
        return false
    end

    local gui = Instance.new("ScreenGui")
    gui.Name = "HitboxGayGui"
    gui.Parent = CoreGui
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 150, 0, 50)
    btn.Position = UDim2.new(0.4, 0, 0.2, 0)
    btn.Text = "Hitbox: OFF"
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Active = true
    btn.Draggable = true
    btn.Parent = gui

    local lastText = "Hitbox: OFF"
    task.spawn(function()
        while true do
            RunService.RenderStepped:Wait()
            local txt = HitboxGay and "Hitbox: ON" or "Hitbox: OFF"
            if txt ~= lastText then btn.Text = txt; lastText = txt end
        end
    end)

    local function getRoot(c) return c and c:FindFirstChild("HumanoidRootPart") end
    local checkBoxSize = Vector3.new(100, 50, 100)

    local function isDescendantOf(o, p) return o and p and o:IsDescendantOf(p) end

    local function getNearestHumanoid()
        if not speaker.Character then return nil end
        local r = getRoot(speaker.Character)
        if not r then return nil end
        local c = speaker.Character
        local isS = isDescendantOf(c, Workspace.Players:FindFirstChild("Survivors"))
        local isK = isDescendantOf(c, Workspace.Players:FindFirstChild("Killers"))
        local tg = nil
        if isS then tg = Workspace.Players:FindFirstChild("Killers")
        elseif isK then tg = Workspace.Players:FindFirstChild("Survivors") end
        local parts = Workspace:GetPartBoundsInBox(r.CFrame, checkBoxSize)
        local near, nd = nil, math.huge
        for _, p in pairs(parts) do
            local m = p:FindFirstAncestorOfClass("Model")
            if m and m:FindFirstChild("Humanoid") and m:FindFirstChild("HumanoidRootPart") then
                if m ~= speaker.Character and m.Humanoid.Health > 0 then
                    _G.IsNpc = false
                    local valid = tg and isDescendantOf(m, tg) or true
                    if valid then
                        local hr = m.HumanoidRootPart
                        local d = (hr.Position - r.Position).Magnitude
                        if d < nd then nd = d; near = hr end
                    end
                end
            end
        end
        if not near then
            for _, p in pairs(parts) do
                local m = p:FindFirstAncestorOfClass("Model")
                if m and m:FindFirstChild("Humanoid") and m:FindFirstChild("HumanoidRootPart") and m ~= speaker.Character and m.Humanoid.Health > 0 then
                    _G.IsNpc = true
                    local hr = m.HumanoidRootPart
                    local d = (hr.Position - r.Position).Magnitude
                    if d < nd then nd = d; near = hr end
                end
            end
        end
        return near
    end

    local function startHitboxGay()
        if loopRunning then return end
        loopRunning = true
        task.spawn(function()
            while HitboxGay do
                RunService.Heartbeat:Wait()
                local c = speaker.Character
                local r = getRoot(c)
                local vel, movel = nil, 0.1
                while not (c and c.Parent and r and r.Parent) do
                    RunService.Heartbeat:Wait()
                    c = speaker.Character
                    r = getRoot(c)
                end
                vel = r.Velocity
                local ids = {}
                for id, _ in pairs(autoBlockTriggerAnims) do table.insert(ids, tonumber(id)) end
                if isAnimationPlaying(ids) then
                    local t = getNearestHumanoid()
                    if t then
                        local fp = not _G.IsNpc and t.Position + t.Velocity * 1.2 or t.Position
                        local off = fp - r.Position
                        local dist = off.Magnitude
                        local dir = off.Unit
                        local sp = dist * 6
                        r.Velocity = vel + Vector3.new(dir.X * sp, dir.Y * sp, dir.Z * sp)
                    end
                end
                RunService.RenderStepped:Wait()
                if c and r then r.Velocity = vel end
                RunService.Stepped:Wait()
                if c and r then
                    r.Velocity = vel + Vector3.new(0, movel, 0)
                    movel = -movel
                end
            end
            loopRunning = false
        end)
    end

    btn.MouseButton1Click:Connect(function()
        HitboxGay = not HitboxGay
        if HitboxGay then startHitboxGay() end
    end)
end

