local function sk8_saveHumState(h)
    if not h or sk8_savedHumState[h] then return end
    local s = {}
    pcall(function()
        s.WalkSpeed = h.WalkSpeed
        local o, _ = pcall(function() s.JumpPower = h.JumpPower end)
        if not o then pcall(function() s.JumpPower = h.JumpHeight end) end
        local o2, ar = pcall(function() return h.AutoRotate end)
        if o2 then s.AutoRotate = ar end
        s.PlatformStand = h.PlatformStand
    end)
    sk8_savedHumState[h] = s
end

local function sk8_restoreHumState(h)
    if not h then return end
    local s = sk8_savedHumState[h]
    if not s then return end
    pcall(function()
        if s.WalkSpeed ~= nil then h.WalkSpeed = s.WalkSpeed end
        if s.JumpPower ~= nil then
            local o, _ = pcall(function() h.JumpPower = s.JumpPower end)
            if not o then pcall(function() h.JumpHeight = s.JumpPower end) end
        end
        if s.AutoRotate ~= nil then pcall(function() h.AutoRotate = s.AutoRotate end) end
        if s.PlatformStand ~= nil then h.PlatformStand = s.PlatformStand end
    end)
    sk8_savedHumState[h] = nil
end

