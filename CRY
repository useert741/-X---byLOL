        ["c00lkidd Milestone IV"] = { Idle = "136752484165169", Walk = "124582615971845", Run = "113259297401193" },
    }
    local presetNames = {}
    for n, _ in pairs(AnimPresets) do table.insert(presetNames, n) end
    table.sort(presetNames)

    local customAnimData = { active = false, preset = nil, tracks = { Idle = nil, Walk = nil, Run = nil }, connection = nil }

    local function getHumanoidAndAnimator()
        local c = lp.Character
        if not c then return nil, nil end
        local h = c:FindFirstChildOfClass("Humanoid")
        if not h then return nil, nil end
        local a = h:FindFirstChildOfClass("Animator")
        if not a then a = Instance.new("Animator"); a.Parent = h end
        return h, a
    end

    local function stopCustomAnimations()
        if customAnimData.connection then customAnimData.connection:Disconnect(); customAnimData.connection = nil end
        for _, t in pairs(customAnimData.tracks) do
            if t then t:Stop(); t:Destroy(); customAnimData.tracks[_] = nil end
        end
        customAnimData.active = false
    end

    local function updateAnimation()
        local h, a = getHumanoidAndAnimator()
        if not h or not a or not customAnimData.preset then return end
        local sp = h.MoveDirection.Magnitude
        local ta = sp > 0.5 and (h.WalkSpeed > 20 and "Run" or "Walk") or "Idle"
        local tt = customAnimData.tracks[ta]
        if tt and not tt.IsPlaying then
            for at, tr in pairs(customAnimData.tracks) do
                if tr and tr ~= tt then tr:Stop() end
            end
            tt:Play()
        elseif not tt then
            stopCustomAnimations()
            customAnimData.active = true
            customAnimData.preset = _G.LastSelectedPreset
            local p = AnimPresets[_G.LastSelectedPreset]
            if not p then return end
            for _, at in ipairs({ "Idle", "Walk", "Run" }) do
                local id = p[at]
                if id and id ~= "" then
                    local an = Instance.new("Animation")
                    an.AnimationId = "rbxassetid://" .. id
                    local t = a:LoadAnimation(an)
                    t.Priority = Enum.AnimationPriority.Movement
                    customAnimData.tracks[at] = t
                end
            end
            local nta = h.MoveDirection.Magnitude > 0.5 and (h.WalkSpeed > 20 and "Run" or "Walk") or "Idle"
            local nt = customAnimData.tracks[nta]
            if nt then nt:Play() end
        end
    end

    local function applyPreset(pn)
        local p = AnimPresets[pn]
        if not p then return end
        local h, a = getHumanoidAndAnimator()
        if not h or not a then return end
        stopCustomAnimations()
        customAnimData.active = true
        customAnimData.preset = pn
        for _, at in ipairs({ "Idle", "Walk", "Run" }) do
            local id = p[at]
            if id and id ~= "" then
                local an = Instance.new("Animation")
                an.AnimationId = "rbxassetid://" .. id
                local t = a:LoadAnimation(an)
                t.Priority = Enum.AnimationPriority.Movement
                customAnimData.tracks[at] = t
            end
        end
        local sp = h.MoveDirection.Magnitude
        local tt = customAnimData.tracks[sp > 0.5 and (h.WalkSpeed > 20 and "Run" or "Walk") or "Idle"]
        if tt then tt:Play() end
        customAnimData.connection = svc.Run.RenderStepped:Connect(updateAnimation)
        window:Notify("Anim", "Applied " .. pn, 2)
    end

    local function resetAnimations()
        stopCustomAnimations()
        _G.LastSelectedPreset = nil
        window:Notify("Anim Reset", "Default", 2)
    end

    lp.CharacterAdded:Connect(function()
        task.wait(0.5)
        if _G.LastSelectedPreset and AnimPresets[_G.LastSelectedPreset] then
            applyPreset(_G.LastSelectedPreset)
        end
    end)

    customAnimSection:CreateDropdown("Select Preset", presetNames, function(v) _G.LastSelectedPreset = v end, presetNames[1], false)
    customAnimSection:CreateButton("Apply Preset", function()
        if _G.LastSelectedPreset then applyPreset(_G.LastSelectedPreset) else window:Notify("Error", "Select a preset", 2) end
    end)
    customAnimSection:CreateButton("Reset to Default", resetAnimations)
end)

