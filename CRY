local function getNearestGenerator() local c=lp.Character if not c or not c:FindFirstChild("HumanoidRootPart") then return nil end local rp=c.HumanoidRootPart.Position local mf=workspace:FindFirstChild("Map") if not mf then return nil end local ing=mf:FindFirstChild("Ingame") if not ing then return nil end local mp=ing:FindFirstChild("Map") if not mp then return nil end local near,nd=nil,math.huge for _,g in ipairs(mp:GetChildren()) do if g:IsA("Model") and g.Name=="Generator" and g:FindFirstChild("Remotes") and g.Remotes:FindFirstChild("RE") then local p=g:FindFirstChild("Main") or g:FindFirstChild("PrimaryPart") if p then local d=(p.Position-rp).Magnitude if d<nd then nd=d near=g end end end end return near end
