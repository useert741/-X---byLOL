local function RemoveESP(m)
    if not m then return end
    for i = #PlayerESPData, 1, -1 do
        if PlayerESPData[i].model == m then table.remove(PlayerESPData, i) end
    end
    for i = #ObjectESPData, 1, -1 do
        if ObjectESPData[i].model == m then table.remove(ObjectESPData, i) end
    end
    pcall(function()
        if m:FindFirstChild("TAOWARE_Highlight") then m.TAOWARE_Highlight:Destroy() end
        if m:FindFirstChild("TAOWARE_Billboard") then m.TAOWARE_Billboard:Destroy() end
    end)
end

local function CreateTracerBeam(model, part, color)
    if not model or not part or not part:IsA("BasePart") or TracerData[model] then return end
    local from = Instance.new("Part")
    from.Size = Vector3.new(0.2, 0.2, 0.2)
    from.Anchored = true
    from.CanCollide = false
    from.Transparency = 1
    from.Parent = workspace.Terrain or workspace
    local to = part
    local attach0 = Instance.new("Attachment", from)
    local attach1 = Instance.new("Attachment", to)
    local beam = Instance.new("Beam")
    beam.Attachment0 = attach0
    beam.Attachment1 = attach1
    beam.Color = ColorSequence.new(color or Color3.fromRGB(255, 255, 255))
    beam.Transparency = NumberSequence.new(0.5)
    beam.Width0 = 0.1
    beam.Width1 = 0.1
    beam.Parent = from
    TracerData[model] = { beam = beam, from = from, part = part }
end

local function RemoveTracerBeam(model)
    if TracerData[model] then
        pcall(function()
            TracerData[model].beam:Destroy()
            TracerData[model].from:Destroy()
        end)
        TracerData[model] = nil
    end
end

local function UpdateTracers()
    for m, d in pairs(TracerData) do
        if d.from and d.part and d.part.Parent then
            local cam = workspace.CurrentCamera
            if d.from and d.part then
                local pos, os = cam:WorldToViewportPoint(d.part.Position)
                if os then
                    local screenMid = Vector2.new(cam.ViewportSize.X / 2, 0)
                    local worldMid = cam:ViewportPointToRay(screenMid.X, screenMid.Y, 0).Origin + cam.CFrame.LookVector * 10
                    d.from.Position = worldMid
                else
                    RemoveTracerBeam(m)
                end
            end
        else
            RemoveTracerBeam(m)
        end
    end
end

