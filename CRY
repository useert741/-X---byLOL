local function checkHitboxCollision()
    if not hitboxDetectionEnabled then return end
    local char = lp.Character
    if not char then return end
    local queryPart = char:FindFirstChild("QueryHitbox")
    if not queryPart or not queryPart:IsA("BasePart") then return end
    local myPos = queryPart.Position

    local killerFolder = getKillersFolder()
    if not killerFolder then return end

    for _, killer in ipairs(killerFolder:GetChildren()) do
        if not killer:IsA("Model") then continue end
        local hrp = killer:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        if BlockSettings.EnableDistanceCheck then
            local dist = (hrp.Position - myPos).Magnitude
            if dist > BlockSettings.TriggerDistance then continue end
        end

        local center = hrp.CFrame
        local forward = center.LookVector
        local up = center.UpVector
        local right = center.RightVector

        local offsetCenter = center + forward * BlockSettings.HitboxOffset

        if isPointInBox(myPos, offsetCenter, forward, up, right, BlockSettings.HitboxSize) then
            local isC00lkidd = false
            if killer.Name:lower():find("c00lkidd") or killer:GetAttribute("ActorDisplayName") == "c00lkidd" then
                isC00lkidd = true
            end
            if isC00lkidd then
                local shouldSkip = false
                local hum = killer:FindFirstChildOfClass("Humanoid")
                local animator = hum and hum:FindFirstChildOfClass("Animator")
                if animator then
                    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                        local animId = track.Animation.AnimationId:match("%d+")
                        if animId and c00lkiddSkipAnims[animId] then
                            shouldSkip = true
                            break
                        end
                    end
                end
                if not shouldSkip then
                    for _, sound in ipairs(killer:GetDescendants()) do
                        if sound:IsA("Sound") and sound.IsPlaying then
                            local sid = tostring(sound.SoundId):match("%d+")
                            if sid and c00lkiddSkipSounds[sid] then
                                shouldSkip = true
                                break
                            end
                        end
                    end
                end
                if not shouldSkip then
                    pressBlock()
                    return
                end
            else
                local hum = killer:FindFirstChildOfClass("Humanoid")
                local animator = hum and hum:FindFirstChildOfClass("Animator")
                local hasAttackAnim = false
                if animator then
                    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                        local animId = track.Animation.AnimationId:match("%d+")
                        if animId and autoBlockTriggerAnims[animId] then
                            hasAttackAnim = true
                            break
                        end
                    end
                end
                local hasAttackSound = false
                for _, sound in ipairs(killer:GetDescendants()) do
                    if sound:IsA("Sound") and sound.IsPlaying then
                        local sid = tostring(sound.SoundId):match("%d+")
                        if sid and autoBlockTriggerSounds[sid] then
                            hasAttackSound = true
                            break
                        end
                    end
                end
                if hasAttackAnim or hasAttackSound then
                    pressBlock()
                    return
                end
            end
        end
    end
end

