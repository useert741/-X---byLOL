local flow={on=false,speed=0.04}
local function flowKey(n) return n.row.."-"..n.col end
local function flowNeighbour(r1,c1,r2,c2) if r2==r1-1 and c2==c1 then return"up" end if r2==r1+1 and c2==c1 then return"down" end if r2==r1 and c2==c1-1 then return"left" end if r2==r1 and c2==c1+1 then return"right" end return false end
local function flowOrder(path,ep) if not path or #path==0 then return path end local lk={} for _,n in ipairs(path) do lk[flowKey(n)]=n end local st for _,e in ipairs(ep or{}) do for _,n in ipairs(path) do if n.row==e.row and n.col==e.col then st={row=e.row,col=e.col} break end end if st then break end end if not st then for _,n in ipairs(path) do local nb=0 for _,d in ipairs({{-1,0},{1,0},{0,-1},{0,1}}) do if lk[(n.row+d[1]).."-"..(n.col+d[2])] then nb=nb+1 end end if nb==1 then st={row=n.row,col=n.col} break end end end if not st then st={row=path[1].row,col=path[1].col} end local pool,ord={},{} for _,n in ipairs(path) do pool[flowKey(n)]={row=n.row,col=n.col} end local cur=st table.insert(ord,{row=cur.row,col=cur.col}) pool[flowKey(cur)]=nil while next(pool) do local moved=false for k,node in pairs(pool) do if flowNeighbour(cur.row,cur.col,node.row,node.col) then table.insert(ord,{row=node.row,col=node.col}) pool[k]=nil cur=node moved=true break end end if not moved then break end end return ord end
local function flowSolve(p) if not p or not p.Solution then return end local idx={} for i=1,#p.Solution do idx[i]=i end for i=#idx,2,-1 do local j=math.random(1,i) idx[i],idx[j]=idx[j],idx[i] end for _,ci in ipairs(idx) do local s=p.Solution[ci] if not s then continue end local ord=flowOrder(s,p.targetPairs[ci]) if not ord or #ord==0 then continue end p.paths[ci]={} for _,n in ipairs(ord) do table.insert(p.paths[ci],{row=n.row,col=n.col}) p:updateGui() task.wait(flow.speed) end task.wait(flow.speed) p:checkForWin() end end
do local modFolder=svc.RS:FindFirstChild("Modules") local miniFolder=modFolder and modFolder:FindFirstChild("Minigames") local fgFolder=miniFolder and miniFolder:FindFirstChild("FlowGameManager") local fgModule=fgFolder and fgFolder:FindFirstChild("FlowGame") if fgModule then local ok,FG=pcall(require,fgModule) if ok and FG and FG.new then local orig=FG.new FG.new=function(...) local p=orig(...) if flow.on then task.spawn(function() task.wait(0.3) flowSolve(p) end) end return p end end end end
