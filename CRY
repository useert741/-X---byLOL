local function CreateESP(m,c,isG,isI,isP,isPD,isZ,isT,isSB,isR,isK) if not m or m:FindFirstChild("TAOWARE_Highlight") then return end if isG and m:FindFirstChild("Progress") and m.Progress.Value==100 then return end if IsRagdoll(m) then return end local tp if isG then tp=GetGeneratorPart(m) elseif isI then tp=m:FindFirstChild("ItemRoot") elseif isP or isPD or isZ or isT or isSB or isR then tp=m:IsA("BasePart") and m or m:FindFirstChildWhichIsA("BasePart",true) else tp=m:FindFirstChild("HumanoidRootPart") end if not tp then return end local hl=Instance.new("Highlight") hl.Name="TAOWARE_Highlight" hl.Adornee=m hl.FillColor=c hl.OutlineColor=c if isK then hl.FillTransparency=ESPSettings.killerFillTransparency hl.OutlineTransparency=ESPSettings.killerOutlineTransparency elseif not isG and not isI and not isP and not isPD and not isZ and not isT and not isSB and not isR then hl.FillTransparency=ESPSettings.survivorFillTransparency hl.OutlineTransparency=ESPSettings.survivorOutlineTransparency else hl.FillTransparency=0.7 hl.OutlineTransparency=0.3 end hl.Parent=m local bb=Instance.new("BillboardGui") bb.Name="TAOWARE_Billboard" bb.Adornee=tp bb.Size=UDim2.new(0,100,0,30) bb.StudsOffset=Vector3.new(0,4,0) bb.AlwaysOnTop=true bb.Parent=m if not isG and not isI and not isP and not isPD and not isZ and not isT and not isSB and not isR then local h=m:FindFirstChild("Humanoid") local nl=Instance.new("TextLabel") nl.Size=UDim2.new(1,0,0.33,0) nl.Position=UDim2.new(0,0,0,0) nl.BackgroundTransparency=1 nl.Text="Loading..." nl.Font=Enum.Font.GothamBlack nl.TextColor3=c nl.TextSize=8 nl.TextStrokeTransparency=0.6 nl.Parent=bb local hlbl=Instance.new("TextLabel") hlbl.Size=UDim2.new(1,0,0.33,0) hlbl.Position=UDim2.new(0,0,0.3,0) hlbl.BackgroundTransparency=1 hlbl.Text="HP: "..(h and string.format("%.0f",h.Health) or "N/A") hlbl.Font=Enum.Font.GothamBlack hlbl.TextColor3=c hlbl.TextSize=8 hlbl.TextStrokeTransparency=0.6 hlbl.Parent=bb local espd={model=m,nameLabel=nl,hpLabel=hlbl,color=c,isKiller=isK} table.insert(PlayerESPData,espd) UpdatePlayerBillboardText(espd) m:GetAttributeChangedSignal("ActorDisplayName"):Connect(function() UpdatePlayerBillboardText(espd) end) m:GetAttributeChangedSignal("SkinNameDisplay"):Connect(function() UpdatePlayerBillboardText(espd) end) m:GetAttributeChangedSignal("IsFakeNoli"):Connect(function() UpdatePlayerBillboardText(espd) end) if h then h:GetPropertyChangedSignal("Health"):Connect(function() UpdatePlayerBillboardText(espd) end) h:GetPropertyChangedSignal("MaxHealth"):Connect(function() UpdatePlayerBillboardText(espd) end) end elseif isG then local nl=Instance.new("TextLabel") nl.Size=UDim2.new(1,0,0.5,0) nl.Position=UDim2.new(0,0,0,0) nl.BackgroundTransparency=1 nl.Text="generator" nl.Font=Enum.Font.GothamBlack nl.TextColor3=c nl.TextSize=8 nl.TextStrokeTransparency=0.6 nl.Parent=bb local pl=Instance.new("TextLabel") pl.Size=UDim2.new(1,0,0.5,0) pl.Position=UDim2.new(0,0,0.5,0) pl.BackgroundTransparency=1 pl.Text="Progress: 0%" pl.Font=Enum.Font.GothamBlack pl.TextColor3=c pl.TextSize=8 pl.TextStrokeTransparency=0.6 pl.Parent=bb local espd={model=m,nameLabel=nl,progressLabel=pl,highlight=hl,billboard=bb} table.insert(ObjectESPData,espd) UpdateGeneratorProgress(espd) local p=m:FindFirstChild("Progress") if p then p:GetPropertyChangedSignal("Value"):Connect(function() UpdateGeneratorProgress(espd) end) end else local dn=m.Name if isPD then dn="Pizza Delivery" elseif isZ then dn="Zombie" elseif isT then dn="Tripwire" elseif isSB then dn="Subspace Box" elseif isR then dn="Respawn" end local tl=Instance.new("TextLabel") tl.Size=UDim2.new(1,0,1,0) tl.BackgroundTransparency=1 tl.Text=dn tl.Font=Enum.Font.GothamBlack tl.TextColor3=c tl.TextSize=8 tl.TextStrokeTransparency=0.6 tl.Parent=bb table.insert(ObjectESPData,{model=m,highlight=hl,billboard=bb}) end end
local function RemoveESP(m) if not m then return end for i=#PlayerESPData,1,-1 do if PlayerESPData[i].model==m then table.remove(PlayerESPData,i) end end for i=#ObjectESPData,1,-1 do if ObjectESPData[i].model==m then table.remove(ObjectESPData,i) end end pcall(function() if m:FindFirstChild("TAOWARE_Highlight") then m.TAOWARE_Highlight:Destroy() end if m:FindFirstChild("TAOWARE_Billboard") then m.TAOWARE_Billboard:Destroy() end end) end
local function CreateTracerBeam(model, part, color)
    if not model or not part or not part:IsA("BasePart") or TracerData[model] then return end
    local from = Instance.new("Part")
    from.Size = Vector3.new(0.2, 0.2, 0.2)
    from.Anchored = true
    from.CanCollide = false
    from.Transparency = 1
    from.Parent = workspace.Terrain or workspace
    local to = part
    local attach0 = Instance.new("Attachment", from)
    local attach1 = Instance.new("Attachment", to)
    local beam = Instance.new("Beam")
    beam.Attachment0 = attach0
    beam.Attachment1 = attach1
    beam.Color = ColorSequence.new(color or Color3.fromRGB(255,255,255))
    beam.Transparency = NumberSequence.new(0.5)
    beam.Width0 = 0.1
    beam.Width1 = 0.1
    beam.Parent = from
    TracerData[model] = {beam = beam, from = from, part = part}
end
local function RemoveTracerBeam(model) if TracerData[model] then pcall(function() TracerData[model].beam:Destroy() TracerData[model].from:Destroy() end) TracerData[model]=nil end end
local function UpdateTracers() for m,d in pairs(TracerData) do if d.from and d.part and d.part.Parent then local cam = workspace.CurrentCamera local pos, os = cam:WorldToViewportPoint(d.part.Position) if os then local screenMid = Vector2.new(cam.ViewportSize.X/2, 0) local worldMid = cam:ViewportPointToRay(screenMid.X, screenMid.Y, 0).Origin + cam.CFrame.LookVector * 10 d.from.Position = worldMid else RemoveTracerBeam(m) end else RemoveTracerBeam(m) end end end
