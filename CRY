local function UpdatePlayerBillboardText(d) if not d or not d.model or not d.nameLabel then return end local m=d.model local isK=d.isKiller local at=m:GetAttribute("ActorDisplayName") or(isK and "KILLER" or "SURVIVOR") local st=m:GetAttribute("SkinNameDisplay") if at=="Noli" and m:GetAttribute("IsFakeNoli")==true then at=at.." (Fake)" end local dt=at local sk=(isK and ESPSettings.killerSkinESP) or(not isK and ESPSettings.survivorSkinESP) if sk and st and tostring(st)~="" then dt=dt.." | "..st end d.nameLabel.Text=dt if d.hpLabel then local h=m:FindFirstChild("Humanoid") if h then local hp=math.floor(h.Health) local mh=math.floor(h.MaxHealth) d.hpLabel.Text=string.format("HP: %d/%d",hp,mh) end end local hl=m:FindFirstChild("TAOWARE_Highlight") if hl then if isK then hl.FillTransparency=ESPSettings.killerFillTransparency hl.OutlineTransparency=ESPSettings.killerOutlineTransparency else hl.FillTransparency=ESPSettings.survivorFillTransparency hl.OutlineTransparency=ESPSettings.survivorOutlineTransparency end end end
