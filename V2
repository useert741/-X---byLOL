        local now = tick()
        if now - lastAttackTime < ATTACK_COOLDOWN then return end
        lastAttackTime = now
        StartAttack(killer, queryHitbox, nil)
    end
    if animator then
        local animConn = animator.AnimationPlayed:Connect(function(track)
            if not _G.AutoBlockEnabled then return end
