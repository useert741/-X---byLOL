local function startBackstabLoop(killerModel, track)
    if BackstabSettings.LoopConnection then
        BackstabSettings.LoopConnection:Disconnect()
    end
    local char = LP.Character
    if not char then stopBackstab(); return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then hum.AutoRotate = false end
    BackstabSettings.LoopConnection = RunService.RenderStepped:Connect(function()
        if not BackstabSettings.Active then stopBackstab(); return end
        if not killerModel or not killerModel.Parent then stopBackstab(); return end
        if killerModel:GetAttribute("IsFakeNoli") == true then
            debugLog("Target became fake Noli, stopping.")
            stopBackstab()
            return
        end
        local myChar = LP.Character
        if not myChar or not myChar.Parent then stopBackstab(); return end
        local root = myChar:FindFirstChild("HumanoidRootPart")
        local killerRoot = killerModel:FindFirstChild("HumanoidRootPart")
        if not root or not killerRoot then stopBackstab(); return end
        local behindOffset = -killerRoot.CFrame.LookVector * BackstabSettings.Offset
            + killerRoot.CFrame.LookVector * BackstabSettings.ForwardOffset
        local targetPos = killerRoot.Position + behindOffset + Vector3.new(0, 0.5, 0)
        root.CFrame = CFrame.new(targetPos, killerRoot.Position)
    end)
    local function onAnimationEnd()
        stopBackstab()
    end
    if track and track.Parent then
        track.Stopped:Connect(onAnimationEnd)
        track.Ended:Connect(onAnimationEnd)
        local ancConn
        ancConn = track.AncestryChanged:Connect(function()
            if not track.Parent then
                ancConn:Disconnect()
                stopBackstab()
            end
        end)
    else
        task.delay(BackstabSettings.TeleportDuration + 0.5, function()
            if BackstabSettings.Active and BackstabSettings.ActiveTrack == track then
                stopBackstab()
            end
        end)
    end
end
local function performBackstab(killerModel, track, shouldLock)
    if not killerModel or not killerModel.Parent then return false end
    local myChar = LP.Character
    if not myChar then return false end
    local root = myChar:FindFirstChild("HumanoidRootPart")
    local killerRoot = killerModel:FindFirstChild("HumanoidRootPart")
    if not root or not killerRoot then return false end
    if killerModel:GetAttribute("IsFakeNoli") == true then return false end
    local behindOffset = -killerRoot.CFrame.LookVector * BackstabSettings.Offset
        + killerRoot.CFrame.LookVector * BackstabSettings.ForwardOffset
    local targetPos = killerRoot.Position + behindOffset + Vector3.new(0, 0.5, 0)
    local targetCF = CFrame.new(targetPos, killerRoot.Position)
    if BackstabSettings.Mode == "Teleport" then
        local startPos = root.CFrame
        root.CFrame = targetCF
        if track then
            local function returnToStart()
                local charNow = LP.Character
                if charNow and charNow:FindFirstChild("HumanoidRootPart") then
                    charNow.HumanoidRootPart.CFrame = startPos
                end
            end
            track.Stopped:Connect(returnToStart)
            track.Ended:Connect(returnToStart)
        else
            task.delay(0.5, function()
                local charNow = LP.Character
                if charNow and charNow:FindFirstChild("HumanoidRootPart") then
                    charNow.HumanoidRootPart.CFrame = startPos
                end
            end)
        end
        return true
    end
    local startCF = root.CFrame
    local steps = BackstabSettings.TeleportSmoothness
    local stepTime = BackstabSettings.TeleportDuration / steps
    for i = 1, steps do
        root.CFrame = startCF:Lerp(targetCF, i / steps)
        task.wait(stepTime)
    end
    root.CFrame = targetCF
    if shouldLock then
        BackstabSettings.Active = true
        BackstabSettings.ActiveKiller = killerModel
        BackstabSettings.ActiveTrack = track
        startBackstabLoop(killerModel, track)
    end
    return true
end
local function getNearestKillerForBackstab()
    local killers = getKillersFolder()
    if not killers then return nil end
    local myChar = LP.Character
    if not myChar then return nil end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    local nearest, nearestDist = nil, math.huge
    for _, killer in ipairs(killers:GetChildren()) do
        if killer:IsA("Model") and killer:FindFirstChild("HumanoidRootPart") and killer:GetAttribute("IsFakeNoli") ~= true then
            local dist = (killer.HumanoidRootPart.Position - myRoot.Position).Magnitude
            if dist <= BackstabSettings.Distance and dist < nearestDist then
                nearestDist = dist
                nearest = killer
            end
        end
    end
    return nearest
end
